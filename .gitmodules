[submodule "dracula/dracula-theme"]
	path = dracula/dracula-theme
	url = https://github.com/zenorocha/dracula-theme/
[submodule "zsh/oh-my-zsh"]
	path = zsh/oh-my-zsh
	url = https://github.com/robbyrussell/oh-my-zsh.git
[submodule "vim/vim.symlink/bundle/Vundle.vim"]
	path = vim/vim.symlink/bundle/Vundle.vim
	url = https://github.com/VundleVim/Vundle.vim.git
[submodule "private"]
	path = private
	url = git@gitlab.com:nathantsoi/dotfiles-private.git
